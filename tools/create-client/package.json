{
  "name": "@frontrangesystems/business-os-create-client",
  "version": "0.0.1",
  "description": "Scaffolds a thin per-client Business OS install repo.",
  "type": "module",
  "bin": {
    "create-business-os-client": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "../../templates/client-starter"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/bin.ts",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "tools/create-client"
  }
}
