{
  "name": "@frontrangesystems/business-os-core",
  "version": "0.0.4",
  "description": "Fastify server, auth, audit log, secrets, settings — the framework's runnable spine.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./secrets": {
      "types": "./dist/secrets/index.d.ts",
      "import": "./dist/secrets/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js"
    },
    "./boot": {
      "types": "./dist/boot/start.d.ts",
      "import": "./dist/boot/start.js"
    },
    "./inventory": {
      "types": "./dist/inventory.d.ts",
      "import": "./dist/inventory.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@frontrangesystems/business-os-api-contract": "workspace:^",
    "@frontrangesystems/business-os-db": "workspace:^",
    "@fastify/static": "^7.0.4",
    "@sentry/node": "^8.32.0",
    "argon2": "^0.41.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.0",
    "libsodium-wrappers": "^0.7.13",
    "otpauth": "^9.3.2",
    "pino": "^9.3.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.13",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "packages/core"
  }
}
