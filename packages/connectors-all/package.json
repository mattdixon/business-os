{
  "name": "@business-os/connectors-all",
  "version": "0.0.1",
  "description": "Aggregator package — re-exports every framework connector so client shells can registerMany() instead of importing each one individually.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@business-os/connector-anthropic": "workspace:^",
    "@business-os/connector-crm-stub": "workspace:^",
    "@business-os/connector-email-gmail-composio": "workspace:^",
    "@business-os/connector-email-inbox-gmail-composio": "workspace:^",
    "@business-os/connector-email-inbox-imap": "workspace:^",
    "@business-os/connector-email-inbox-outlook-composio": "workspace:^",
    "@business-os/connector-email-stub": "workspace:^",
    "@business-os/connector-openai": "workspace:^",
    "@business-os/connector-sdk": "workspace:^",
    "@business-os/db": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
