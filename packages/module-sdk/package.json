{
  "name": "@business-os/module-sdk",
  "version": "0.0.1",
  "description": "The interface every Business OS module implements — schema + server routes + optional UI pages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests in module-sdk (interface package)' && exit 0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@business-os/db": "workspace:^",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
