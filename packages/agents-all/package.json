{
  "name": "@frontrangesystems/business-os-agents-all",
  "version": "0.0.3",
  "description": "Aggregator package — re-exports every framework agent so client shells can registerManyAgents() instead of importing each one individually.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@frontrangesystems/business-os-agent-digest": "workspace:^",
    "@frontrangesystems/business-os-agent-inbox-categorize": "workspace:^",
    "@frontrangesystems/business-os-agent-inbox-cleanup": "workspace:^",
    "@frontrangesystems/business-os-agent-inbox-surface": "workspace:^",
    "@frontrangesystems/business-os-agent-leadgen": "workspace:^",
    "@frontrangesystems/business-os-agent-prospecting": "workspace:^",
    "@frontrangesystems/business-os-agent-sdk": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "packages/agents-all"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
