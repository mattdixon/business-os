# Control-plane database (used by API + CLI)
CONTROL_PLANE_DATABASE_URL=postgres://businessos:businessos@localhost:5432/businessos_control

# Postgres admin URL — used only by the tenant CLI to CREATE tenant databases
# (must have CREATEDB privilege)
POSTGRES_ADMIN_URL=postgres://businessos:businessos@localhost:5432/postgres

# Tenant DB connection template — {{db_name}} is substituted at runtime
TENANT_DATABASE_URL_TEMPLATE=postgres://businessos:businessos@localhost:5432/{{db_name}}

# Encryption key for tenant DB passwords (libsodium key, base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# (F1 stores tenant DB password in plaintext in dev; encryption added when needed by F2.)
SECRETS_KEY=

# API server
API_PORT=3000
API_BASE_DOMAIN=businessos.localhost
NODE_ENV=development
LOG_LEVEL=info

# Sentry (leave empty in dev to disable)
SENTRY_DSN=
