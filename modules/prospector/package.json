{
  "name": "@frontrangesystems/business-os-module-prospector",
  "version": "0.0.2",
  "description": "Prospector — surfaces scored bid opportunities + accepts thumbs feedback. Reads bids written by the bid-watcher agent; owns its own feedback table.",
  "type": "module",
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@frontrangesystems/business-os-core": "workspace:^",
    "@frontrangesystems/business-os-module-sdk": "workspace:^",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "fastify": "^4.28.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "fastify": "^4.28.0",
    "react": "^18.3.1",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "modules/prospector"
  }
}
