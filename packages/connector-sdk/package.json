  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "packages/connector-sdk"
  }
