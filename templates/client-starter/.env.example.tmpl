# {{CLIENT_NAME}} — Business OS instance config
#
# Edit this file (or your hosting provider's secrets UI) to configure the
# install. Per-agent and per-connector settings + credentials live in the
# DB and are managed via the operator UI — they DO NOT belong in here.

# Postgres your install runs against. Use a dedicated DB per client.
DATABASE_URL=postgres://businessos:businessos@localhost:5432/{{CLIENT_SLUG}}_os

# 32 random bytes, base64 — encrypts secrets at rest.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_KEY={{GENERATED_SECRETS_KEY}}

CLIENT_SLUG={{CLIENT_SLUG}}
CLIENT_NAME={{CLIENT_NAME}}

API_PORT=4673
NODE_ENV=development
LOG_LEVEL=info

# Leave empty in dev to disable
SENTRY_DSN=

# Seed-dev script — only consumed when you run `pnpm seed:dev`. Defaults are
# fine for local dev; never run seed:dev in production.
SEED_DEV_EMAIL=admin@localhost
SEED_DEV_PASSWORD=change-me-now-please
CLIENT_ICP_EXAMPLE=
CLIENT_OFFER_EXAMPLE=
