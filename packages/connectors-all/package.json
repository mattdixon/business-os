{
  "name": "@frontrangesystems/business-os-connectors-all",
  "version": "0.0.3",
  "description": "Aggregator package — re-exports every framework connector so client shells can registerMany() instead of importing each one individually.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@frontrangesystems/business-os-connector-anthropic": "workspace:^",
    "@frontrangesystems/business-os-connector-crm-stub": "workspace:^",
    "@frontrangesystems/business-os-connector-email-gmail-composio": "workspace:^",
    "@frontrangesystems/business-os-connector-email-inbox-gmail-composio": "workspace:^",
    "@frontrangesystems/business-os-connector-email-inbox-imap": "workspace:^",
    "@frontrangesystems/business-os-connector-email-inbox-outlook-composio": "workspace:^",
    "@frontrangesystems/business-os-connector-email-stub": "workspace:^",
    "@frontrangesystems/business-os-connector-openai": "workspace:^",
    "@frontrangesystems/business-os-connector-resend": "workspace:^",
    "@frontrangesystems/business-os-connector-sdk": "workspace:^",
    "@frontrangesystems/business-os-db": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "packages/connectors-all"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
