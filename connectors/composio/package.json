{
  "name": "@frontrangesystems/business-os-connector-composio",
  "version": "0.0.4",
  "description": "Substrate for Composio-backed connectors — shared client, version pinning, error mapping. Not a connector itself.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@frontrangesystems/business-os-connector-sdk": "workspace:^",
    "@composio/core": "0.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "connectors/composio"
  }
}
