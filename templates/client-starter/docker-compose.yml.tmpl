services:
  postgres:
    image: postgres:16-alpine
    container_name: {{CLIENT_SLUG}}-os-postgres
    environment:
      POSTGRES_USER: businessos
      POSTGRES_PASSWORD: businessos
      POSTGRES_DB: {{CLIENT_SLUG}}_os
    ports:
      # Host port 4732 → container 5432. Off-default to avoid colliding with
      # native Postgres installs or other Postgres containers. Matches
      # DATABASE_URL in .env.example.
      - "4732:5432"
    volumes:
      - {{CLIENT_SLUG}}-os-pgdata:/var/lib/postgresql/data

volumes:
  {{CLIENT_SLUG}}-os-pgdata:
