{
  "name": "@business-os/runtime",
  "version": "0.0.1",
  "description": "Boots agents: registry, ctx factory, runAgent, scheduler entrypoint.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@business-os/agent-sdk": "workspace:^",
    "@business-os/connector-sdk": "workspace:^",
    "@business-os/db": "workspace:^",
    "@business-os/core": "workspace:^",
    "croner": "^8.1.0",
    "drizzle-orm": "^0.33.0",
    "pg-boss": "^10.1.5",
    "pino": "^9.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "postgres": "^3.4.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
