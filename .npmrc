# libsodium-wrappers' ESM build does `import "./libsodium.mjs"` expecting the
# sibling `libsodium` package's mjs to be co-located. Under pnpm's default
# strict node_modules layout they end up in separate dirs and the import fails.
# Hoist the libsodium namespace to the top level so the sibling import resolves.
public-hoist-pattern[]=*libsodium*
