{
  "name": "@frontrangesystems/business-os-ui",
  "version": "0.0.3",
  "description": "Operator UI for Business OS installs. Library (createOperatorApp) + a default pre-built bundle.",
  "type": "module",
  "main": "./src/lib/manifest.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/lib/manifest.ts",
      "import": "./src/lib/manifest.ts"
    },
    "./app": {
      "types": "./src/app.tsx",
      "import": "./src/app.tsx"
    },
    "./styles.css": "./src/styles.css",
    "./tailwind-content": "./src/lib/tailwind-content.js",
    "./dist": "./dist"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests in ui (functional coverage via playwright later)' && exit 0"
  },
  "dependencies": {
    "@frontrangesystems/business-os-module-sdk": "workspace:^",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontrangesystems/business-os.git",
    "directory": "packages/ui"
  }
}
