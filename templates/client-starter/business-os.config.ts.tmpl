/**
 * {{CLIENT_NAME}} — Business OS registry.
 *
 * This file declares WHAT is installed at this client. Schedules,
 * credentials, on/off, and per-agent settings live in the DB and are
 * managed in the operator UI — NOT here.
 *
 * To add a shared agent: import + register it below. To add a client-custom
 * agent: drop it under `./agents/` and register it the same way.
 */

import { Registry, Scheduler } from '@business-os/runtime';
import { createConnectorResolver } from '@business-os/runtime';
import anthropic from '@business-os/connector-anthropic';
import openai from '@business-os/connector-openai';
import emailStub from '@business-os/connector-email-stub';
import crmStub, { crmStubMigrations } from '@business-os/connector-crm-stub';
import leadgen from '@business-os/agent-leadgen';
import prospecting from '@business-os/agent-prospecting';

// ---- Modules (uncomment + add deps to register one) ----
// Modules own a slice of business state: their own tables, REST routes, and
// optional UI pages. The framework runs their migrations + mounts their routes
// at /modules/<slug>/* automatically.
//
// import exampleModule from '@business-os/module-example';

import type { MigrationOwner } from '@business-os/db';

export function buildRegistry(): Registry {
  const registry = new Registry();

  // ---- Connectors ----
  // LLM providers — operator picks per agent via the settings UI.
  registry.registerConnectorProvider(anthropic);
  registry.registerConnectorProvider(openai);

  // Dev/demo providers for email + crm. Swap for real Gmail / HubSpot etc.
  // by registering the corresponding @business-os/connector-* and activating
  // it in the operator UI.
  registry.registerConnectorProvider(emailStub);
  registry.registerConnectorProvider(crmStub);

  // ---- Agents ----
  registry.registerAgent(leadgen);
  registry.registerAgent(prospecting);

  // ---- Modules ----
  // registry.registerModule(exampleModule);

  return registry;
}

/** Additional migration owners for agents + connectors that ship their own. */
export const extraMigrations: MigrationOwner[] = [
  crmStubMigrations,
];

export type { Registry, Scheduler };
export { createConnectorResolver };
