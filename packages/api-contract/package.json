{
  "name": "@frontrangesystems/business-os-api-contract",
  "version": "0.0.3",
  "description": "Zod request/response schemas shared by core, UI, and any 3rd-party client.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
