/**
 * {{CLIENT_NAME}} — Business OS registry.
 *
 * Every framework connector ships via `@business-os/connectors-all` —
 * the operator decides which ones are visible from the Providers admin
 * page, not by editing this file. Credentials, schedules, on/off, and
 * per-agent settings live in the DB and are managed in the operator UI.
 *
 * Add client-custom agents below by dropping them under `./agents/` and
 * registering them the same way as the shared ones.
 */

import { Registry, Scheduler, createConnectorResolver } from '@business-os/runtime';
import {
  allFrameworkConnectors,
  allFrameworkConnectorMigrations,
} from '@business-os/connectors-all';

import leadgen from '@business-os/agent-leadgen';
import prospecting from '@business-os/agent-prospecting';

// ---- Modules (uncomment + add deps to register one) ----
// Modules own a slice of business state: their own tables, REST routes, and
// optional UI pages. The framework runs their migrations + mounts their routes
// at /modules/<slug>/* automatically.
//
// import exampleModule from '@business-os/module-example';

import type { MigrationOwner } from '@business-os/db';

export function buildRegistry(): Registry {
  const registry = new Registry();

  // ---- Connectors ----
  // Every framework connector is registered. The Providers admin page
  // controls which appear in the operator UI's Add Instance dropdown.
  registry.registerMany(allFrameworkConnectors);

  // ---- Agents ----
  registry.registerAgent(leadgen);
  registry.registerAgent(prospecting);

  // ---- Modules ----
  // registry.registerModule(exampleModule);

  return registry;
}

/** Additional migration owners for client-custom agents/connectors. */
export const extraMigrations: MigrationOwner[] = [
  ...allFrameworkConnectorMigrations,
];

export type { Registry, Scheduler };
export { createConnectorResolver };
