# NOTE: This .env.example lives in the FRAMEWORK monorepo. It's used for
# running framework tests and the dev harness, NOT for a real client deploy.
# A real client install gets its own .env, scaffolded by `pnpm create business-os-client`.

# Local Postgres for framework tests / dev harness
DATABASE_URL=postgres://businessos:businessos@localhost:5432/businessos_dev

# Encryption key for secrets at rest (libsodium, base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_KEY=

# Client identity (single-tenant — every install IS a client)
CLIENT_SLUG=dev
CLIENT_NAME="Dev Harness"

# API server
API_PORT=4673
NODE_ENV=development
LOG_LEVEL=info

# Sentry (leave empty in dev to disable)
SENTRY_DSN=
