{
  "name": "@business-os/ui",
  "version": "0.0.1",
  "description": "Operator UI for Business OS installs. Built static assets served by core.",
  "type": "module",
  "main": "./src/lib/manifest.ts",
  "files": ["dist", "src/lib"],
  "exports": {
    ".": {
      "types": "./src/lib/manifest.ts",
      "import": "./src/lib/manifest.ts"
    },
    "./dist": "./dist"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests in ui (functional coverage via playwright later)' && exit 0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
